{
  "manifest_version": 3,
  "name": "Umrah Logistics Capture",
  "version": "1.1.0",
  "description": "Capture itinerary text from any page → send directly to Umrah Logistics Pro",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "clipboardRead"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.nusuk.sa/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
